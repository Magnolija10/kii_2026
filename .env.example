# Copy to .env and adjust. Used by docker-compose (web + db).
# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- PostgreSQL (must match the db service) ---
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_secret

# --- Optional: AI assistant (Ollama). Leave default if not used. ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Image naming (used by compose / CI) ---
IMAGE_NAME=lmsproject-web
IMAGE_TAG=local
